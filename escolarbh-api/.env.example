# ============================================================
# EscolarBH — Template de Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores.
# cp .env.example .env
# ============================================================

# ── Supabase ──
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Conexão PostgreSQL (Supabase Dashboard → Settings → Database)
DATABASE_URL=jdbc:postgresql://db.SEU_PROJECT_ID.supabase.co:5432/postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=

# ── JWT ──
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ── Criptografia LGPD ──
# Gere com: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=

# ── Asaas ──
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# ── Google Maps ──
GOOGLE_MAPS_API_KEY=

# ── ZapSign ──
ZAPSIGN_API_TOKEN=

# ── Firebase ──
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Servidor ──
SERVER_PORT=8080
CORS_ORIGIN=http://localhost:5173

# ── Rust Geo Service ──
GEO_SERVICE_URL=http://localhost:3001
USE_RUST_GEO=false
